<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Free Fire Sensitivity Generator</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #121212; color: white; text-align: center; padding: 20px; }
        .box { background: #1e1e1e; padding: 20px; border-radius: 8px; display: inline-block; margin-top: 20px; }
        input, button { padding: 10px; margin: 10px; border-radius: 4px; border: none; }
        button { background-color: #ff4500; color: white; cursor: pointer; font-weight: bold; }
    </style>
</head>
<body>

    <h1>Free Fire Sensi Generator</h1>
    <div class="box">
        <input type="text" id="device" placeholder="Enter Device Name (e.g., Poco X3)">
        <input type="number" id="dpi" placeholder="Enter DPI (e.g., 400)">
        <br>
        <button onclick="generateSensi()">Generate Perfect Sensi</button>
        
        <div id="result" style="margin-top:20px; font-weight:bold; color:#ffcf40;"></div>
    </div>

    <script>
        function generateSensi() {
            let dpi = parseFloat(document.getElementById('dpi').value);
            if (!dpi || dpi <= 0) {
                document.getElementById('result').innerHTML = "Please enter a valid DPI.";
                return;
            }
            
            // Example custom mathematical formula for in-game slider output
            let generalSensi = Math.min(100, Math.max(50, Math.round((800 / dpi) * 95)));
            let redDot = Math.min(100, generalSensi + 5);
            
            document.getElementById('result').innerHTML = `
                <p>Recommended Settings:</p>
                <p>General: ${generalSensi}</p>
                <p>Red Dot: ${redDot}</p>
                <p>2x Scope: 100</p>
                <p>4x Scope: 100</p>
            `;
        }
    </script>
</body>
</html>
